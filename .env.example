# Tape — environment variables
# Copy to .env. NEVER commit .env.

# ── Claude API (REQUIRED) ─────────────────────────────────────────
# Powers the strategy compiler, critique loop, and swarm tournament.
# Get a key: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Which Opus version to use (default = 4.8)
TAPE_LLM_MODEL=claude-opus-4-8

# ── Polymarket sandbox wallet (REQUIRED for live deployment) ──────
# Each deployed strategy uses this wallet with a code-enforced budget cap.
# Generate API creds: python -m pave_capital.generate_api_key
SANDBOX_PRIVATE_KEY=0x...
SANDBOX_ADDRESS=0x...
SANDBOX_API_KEY=
SANDBOX_API_SECRET=
SANDBOX_API_PASSPHRASE=

# Hard cap on USDC per deployed strategy (USD). Enforced in risk_controls.
TAPE_PER_STRATEGY_BUDGET=25

# ── Backtester ────────────────────────────────────────────────────
# How many days of historical fills to replay
TAPE_BACKTEST_DAYS=90

# Cache directory for downloaded historical data
TAPE_BACKTEST_CACHE=./backtest_cache
